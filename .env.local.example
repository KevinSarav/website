# ============================================================================
# LOCAL DEVELOPMENT OVERRIDES - Copy to .env.local
# ============================================================================
# This file allows you to override .env settings for local development only
# .env.local is in .gitignore and should NEVER be committed to Git
# ============================================================================

# --- LOCAL PORT OVERRIDE ---
# Use a different port for local development if needed
# COMPOSE_PORT=3000

# --- CUSTOM FRONTEND VALUES FOR LOCAL DEV ---
# VITE_SITE_OWNER="Local Dev"
# VITE_ANALYTICS_HOST="http://localhost:8080"

# --- LOCAL ZROK CONFIG ---
# Override the zrok share name for testing
# ZROK_SHARE_NAME="local-test.shares.zrok.io"

# --- DEBUG MODE ---
# NODE_ENV=development
