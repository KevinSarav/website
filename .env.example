# Copy to .env and set real values for your development/local Docker deployment.
# The SITE_* vars are loaded at build time (GitHub Actions) or container startup (Docker).
# 
# For deployments:
# - GitHub Pages: Workflow resolves SITE_PUBLIC_URL from vars.SITE_PUBLIC_URL_PAGES or CNAME
# - Docker self-hosted: Workflow resolves SITE_PUBLIC_URL from vars/secrets SITE_PUBLIC_URL_DOCKER
# - Local dev: You can set SITE_PUBLIC_URL to your local URL if needed

SITE_APP_NAME=Kevin Saravia Showcase
SITE_MY_NAME=Kevin Saravia
SITE_ROLE=Software Engineer
SITE_SUMMARY=REPLACE_ME
SITE_LOCATION=REPLACE_ME
SITE_AVAILABILITY=REPLACE_ME
SITE_PUBLIC_URL=
SITE_GDOC_RESUME_ID=REPLACE_ME
SITE_NOTE_1=REPLACE_ME
SITE_NOTE_2=REPLACE_ME
