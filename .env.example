# Copy to .env and set real values for your deployment.
# The SITE_* vars are loaded at container startup and used in site content.
# Change them in .env/.env.sops and redeploy without rebuilding images.
# Docker Compose env interpolation reference: https://docs.docker.com/compose/how-tos/environment-variables/variable-interpolation/
# Never commit .env. Repo owner should commit only encrypted .env.sops.

SITE_APP_NAME=REPLACE_ME
SITE_MY_NAME=REPLACE_ME
SITE_ROLE=REPLACE_ME
SITE_SUMMARY=REPLACE_ME
SITE_LOCATION=REPLACE_ME
SITE_AVAILABILITY=REPLACE_ME
SITE_PUBLIC_URL=REPLACE_ME
SITE_RESUME_EMBED_URL=REPLACE_ME
SITE_RESUME_DOWNLOAD_URL=REPLACE_ME
SITE_NOTE_1=REPLACE_ME
SITE_NOTE_2=REPLACE_ME
PDF_FILENAME=REPLACE_ME.pdf
