# ============================================================================
# ENVIRONMENT CONFIGURATION - Copy to .env and fill in your values
# ============================================================================
# IMPORTANT: .env is in .gitignore and should NEVER be committed to Git
# ============================================================================

# --- PUBLIC FRONTEND VALUES (exposed in browser bundles) ---
# These are safe to be public and are used by Vite as VITE_* variables
VITE_SITE_OWNER="Your Name"
VITE_CONTACT_EMAIL="contact_placeholder"
VITE_LOCATION="Your Location"
VITE_ANALYTICS_HOST=""

# --- DOCKER COMPOSE CONFIGURATION ---
# Local port for running the website container
COMPOSE_PORT=4173
# Docker image name and tag
COMPOSE_IMAGE_NAME=local/professional-showcase
COMPOSE_IMAGE_TAG=latest
# Container name for easy reference
COMPOSE_CONTAINER_NAME=professional-showcase

# --- ZROK CONFIGURATION ---
# Reserved share name placeholder
ZROK_SHARE_NAME="share_name_placeholder"
# Local service target placeholder
ZROK_TARGET_URL="local_service_placeholder"
# Optional backend placeholder
ZROK_BACKEND=""

# --- CI/CD RUNTIME VALUES ---
# Keep runtime credentials in repository settings, not in this file

# --- NODE ENVIRONMENT ---
NODE_ENV=development
