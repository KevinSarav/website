# Copy to .env and set real values for your development/local Docker deployment.
# The SITE_* vars are loaded at build time (GitHub Actions) or container startup (Docker).
# 
# For deployments:
# - Online host (environment: production-online): Workflow resolves SITE_PUBLIC_URL from vars.SITE_PUBLIC_URL or CNAME
# - Self-hosted (environment: production-selfhost): Workflow resolves SITE_PUBLIC_URL from vars/secrets SITE_PUBLIC_URL
# - Local dev: You can set SITE_PUBLIC_URL to your local URL if needed

SITE_APP_NAME=REPLACE_ME
SITE_MY_NAME=REPLACE_ME
SITE_ROLE=REPLACE_ME
PROFILE_CITY=REPLACE_ME
PROFILE_REGION=REPLACE_ME
PROFILE_COUNTRY=REPLACE_ME
SITE_AVAILABILITY=REPLACE_ME
SITE_PUBLIC_URL=REPLACE_ME
SITE_GDOC_RESUME_ID=REPLACE_ME
RESUME_PDF_FILE_NAME=REPLACE_ME
